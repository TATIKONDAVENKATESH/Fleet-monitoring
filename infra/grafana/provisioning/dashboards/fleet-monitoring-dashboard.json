{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Fleet Monitoring Platform — JVM, HTTP, and business metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_memory_used_bytes{application=\"fleet-monitoring-backend\", area=\"heap\"}",
          "legendFormat": "Heap Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_count{application=\"fleet-monitoring-backend\"}[1m])",
          "legendFormat": "{{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "HTTP P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"fleet-monitoring-backend\"}[5m]))",
          "legendFormat": "P99 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "DB Connection Pool Active",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "hikaricp_connections_active{application=\"fleet-monitoring-backend\"}",
          "legendFormat": "Active Connections"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 20, "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_cpu_usage{application=\"fleet-monitoring-backend\"} * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "percent" }
      }
    },
    {
      "id": 6,
      "title": "Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(http_server_requests_seconds_count{application=\"fleet-monitoring-backend\", status=~\"5..\"}[1m])",
          "legendFormat": "5xx errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 7,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_live_threads{application=\"fleet-monitoring-backend\"}",
          "legendFormat": "Live Threads"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_daemon_threads{application=\"fleet-monitoring-backend\"}",
          "legendFormat": "Daemon Threads"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["fleet", "spring-boot", "jvm"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Fleet Monitoring — Backend Metrics",
  "uid": "fleet-backend-001",
  "version": 1
}
